# Copie este arquivo para ".streamlit/secrets.toml" (mesma pasta) para rodar
# o app na sua máquina, e cole aqui a connection string do seu banco Supabase.
#
# IMPORTANTE: o arquivo "secrets.toml" (sem o ".example") nunca deve ser
# enviado ao GitHub — ele já está no .gitignore por segurança, porque contém
# a senha do seu banco de dados.
#
# No Streamlit Community Cloud, essa mesma chave é configurada em
# "Settings" -> "Secrets" do seu app (não como arquivo, direto no site).

SUPABASE_DB_URL = "postgresql://postgres.xxxxxxxx:SUA_SENHA@aws-0-sa-east-1.pooler.supabase.com:5432/postgres"
